<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#141414">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Profile"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Profile Name"
        android:textColor="@android:color/white"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/profile_name_input"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:hint="Enter name"
        android:inputType="textPersonName"
        android:maxLength="20"
        android:padding="12dp"
        android:textColor="@android:color/white"
        android:textColorHint="#80FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Avatar Color"
        android:textColor="@android:color/white"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/avatar_recycler"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:orientation="horizontal" />

    <TextView
        android:id="@+id/pin_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="PIN (Optional)"
        android:textColor="@android:color/white"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/pin_input"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:hint="4-digit PIN"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:padding="12dp"
        android:textColor="@android:color/white"
        android:textColorHint="#80FFFFFF" />

    <CheckBox
        android:id="@+id/remove_pin_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Remove PIN protection"
        android:textColor="@android:color/white"
        android:buttonTint="@color/simpl_blue"
        android:visibility="gone" />

    <CheckBox
        android:id="@+id/kids_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Kids Profile (content filtering)"
        android:textColor="@android:color/white"
        android:buttonTint="@color/simpl_blue" />

    <TextView
        android:id="@+id/error_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FF6B6B"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="Error message"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/delete_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#B71C1C"
            android:text="Delete"
            android:textColor="@android:color/white"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <Button
            android:id="@+id/cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#333333"
            android:text="@string/action_cancel"
            android:textColor="@android:color/white"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <Button
            android:id="@+id/save_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/simpl_blue"
            android:text="Save"
            android:textColor="@android:color/white"
            android:focusable="true"
            android:focusableInTouchMode="true" />

    </LinearLayout>

</LinearLayout>
