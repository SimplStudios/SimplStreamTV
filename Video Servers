  };

  // Search movies
  const searchMovies = async (query) => {
    try {
      const response = await axios.get(
        `${TMDB_BASE}/search/movie?api_key=${TMDB_API_KEY}&query=${query}`
      );
      setSearchResults(response.data.results);
    } catch (error) {
      console.error('Search failed:', error);
    }
  };

  // Get movie details with IMDB ID
  const getMovieDetails = async (movieId) => {
    try {
      const response = await axios.get(
        `${TMDB_BASE}/movie/${movieId}?api_key=${TMDB_API_KEY}&append_to_response=external_ids,videos,credits`
      );
      setSelectedMovie(response.data);
    } catch (error) {
      console.error('Failed to fetch movie details:', error);
    }
  };

  // Handle search
  const handleSearch = (e) => {
    e.preventDefault();
    if (searchQuery.trim()) {
      searchMovies(searchQuery);
    }
  };

  return (
    <div className="streaming-app">
      <header>
        <h1>Streaming Site</h1>
        <form onSubmit={handleSearch}>
          <input
            type="text"
            placeholder="Search movies..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
          <button type="submit">Search</button>
        </form>
      </header>

      {/* Search Results */}
      <div className="search-results">
        {searchResults.map(movie => (
          <MovieCard
            key={movie.id}
            movie={movie}
            onClick={() => getMovieDetails(movie.id)}
          />
        ))}
      </div>

      {/* Movie Player */}
      {selectedMovie && (
        <MoviePlayer
          movie={selectedMovie}
          provider={provider}
          providers={providers}
          setProvider={setProvider}
        />
      )}
    </div>
  );
};

const MovieCard = ({ movie, onClick }) => (
  <div className="movie-card" onClick={onClick}>
    <img
      src={`https://image.tmdb.org/t/p/w185${movie.poster_path}`}
      alt={movie.title}
    />
    <h3>{movie.title}</h3>
    <p>⭐ {movie.vote_average.toFixed(1)}</p>
  </div>
);

const MoviePlayer = ({ movie, provider, providers, setProvider }) => {
  const imdbId = movie.external_ids?.imdb_id;
  const embedUrl = `${providers[provider]}/movie/${imdbId}`;

  return (
    <div className="movie-player">
      <div className="movie-info">
        <img
          src={`https://image.tmdb.org/t/p/w300${movie.poster_path}`}
          alt={movie.title}
        />
        <div>
          <h2>{movie.title}</h2>
          <p>{movie.overview}</p>
          <p><strong>Rating:</strong> {movie.vote_average.toFixed(1)}/10</p>
          <p><strong>Release Date:</strong> {movie.release_date}</p>
        </div>
      </div>

      <div className="provider-selector">
        <label>Video Source: </label>
        <select value={provider} onChange={(e) => setProvider(e.target.value)}>
          <option value="vidsrc">VidSrc</option>
          <option value="vidfast">VidFast</option>
          <option value="vidzee">Vidzee</option>
          <option value="movies111">111Movies</option>
        </select>
      </div>

      <div className="video-container">
        <iframe
          src={embedUrl}
          width="100%"
          height="500px"
          frameBorder="0"
          allowFullScreen
          allow="autoplay; encrypted-media; picture-in-picture"
        />
      </div>
    </div>
  );
};

export default StreamingApp;
