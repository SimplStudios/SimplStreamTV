### JavaScript Implementation

```javascript
class VidSrcEmbed {
  constructor(containerId) {
    this.container = document.getElementById(containerId);
    this.baseUrl = 'https://vidsrc.to/embed';
  }

  // Embed movie
  embedMovie(imdbId, options = {}) {
    const {
      width = '100%',
      height = '500px',
      autoplay = 0,
      poster = true
    } = options;

    const params = new URLSearchParams({
      autoPlay: autoplay,
      poster: poster ? 1 : 0
    });

    const iframe = document.createElement('iframe');
    iframe.src = `${this.baseUrl}/movie/${imdbId}?${params}`;
    iframe.width = width;
    iframe.height = height;
    iframe.frameBorder = '0';
    iframe.allowFullscreen = true;
    iframe.allow = 'autoplay; fullscreen; picture-in-picture';

    this.container.innerHTML = '';
    this.container.appendChild(iframe);
  }

  // Embed TV episode
  embedEpisode(imdbId, season, episode, options = {}) {
    const {
      width = '100%',
      height = '500px',
      autoplay = 0
    } = options;

    const iframe = document.createElement('iframe');
    iframe.src = `${this.baseUrl}/tv/${imdbId}/${season}/${episode}`;
    iframe.width = width;
    iframe.height = height;
    iframe.frameBorder = '0';
    iframe.allowFullscreen = true;
    iframe.allow = 'autoplay; fullscreen; picture-in-picture';

    this.container.innerHTML = '';
    this.container.appendChild(iframe);
  }

  // Using TMDB ID
  embedMovieTMDB(tmdbId, options = {}) {
    const params = new URLSearchParams({
      tmdb: 1,
      autoPlay: options.autoplay || 0
    });

    const iframe = document.createElement('iframe');
    iframe.src = `https://vidsrc.cc/v2/embed/movie/${tmdbId}?${params}`;
    iframe.width = options.width || '100%';
    iframe.height = options.height || '500px';
    iframe.frameBorder = '0';
    iframe.allowFullscreen = true;

    this.container.innerHTML = '';
    this.container.appendChild(iframe);
  }
}

// Usage
const player = new VidSrcEmbed('player-container');

// Embed Fight Club
player.embedMovie('tt0137523', {
  width: '800px',
  height: '450px',
  autoplay: 1
});

// Embed Game of Thrones S01E01
player.embedEpisode('tt0944947', 1, 1);

// Using TMDB ID
player.embedMovieTMDB('550');
```

### React Component

```jsx
import React from 'react';

const VidSrcPlayer = ({ 
  type = 'movie', 
  imdbId, 
  tmdbId,
  season, 
  episode,
