### Player Events (PostMessage API)

```javascript
// Listen for player events
window.addEventListener('message', (event) => {
  // Verify origin
  if (event.origin !== 'https://vidsrc.to') return;

  if (event.data && event.data.type === 'PLAYER_EVENT') {
    const { event: eventType, currentTime, duration } = event.data.data;
    
    switch(eventType) {
      case 'play':
        console.log('Video started playing');
        break;
      case 'pause':
        console.log('Video paused');
        break;
      case 'ended':
        console.log('Video ended');
        // Load next episode automatically
        break;
      case 'timeupdate':
        console.log(`Progress: ${currentTime}s / ${duration}s`);
        // Save watch progress
        saveProgress(currentTime, duration);
        break;
    }
  }
});

function saveProgress(currentTime, duration) {
  localStorage.setItem('watchProgress', JSON.stringify({
    time: currentTime,
    duration: duration,
    percentage: (currentTime / duration) * 100,
    timestamp: Date.now()
  }));
}
```

