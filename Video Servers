```javascript
// Track watch progress for "Continue Watching" feature
window.addEventListener('message', (event) => {
  // Verify origin
  if (event.origin !== 'https://vidzee.wtf') return;

  if (event.data?.type === 'MEDIA_DATA') {
    const mediaData = event.data.data;
    
    // Save to localStorage
    localStorage.setItem('vidZeeProgress', JSON.stringify(mediaData));
    
    // Or save to database
    saveToDatabase({
      mediaId: mediaData.id,
      currentTime: mediaData.currentTime,
      duration: mediaData.duration,
      percentage: (mediaData.currentTime / mediaData.duration) * 100,
      lastWatched: new Date().toISOString()
    });
  }
});

function saveToDatabase(progressData) {
  fetch('/api/watch-progress', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(progressData)
  });
}
