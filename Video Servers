## Common Implementation Patterns

### Multi-Provider Fallback System

```javascript
class MultiProviderPlayer {
  constructor(containerId) {
    this.container = document.getElementById(containerId);
    this.providers = [
      { name: 'vidsrc', url: 'https://vidsrc.to/embed' },
      { name: 'vidfast', url: 'https://vidfast.to/embed' },
      { name: 'vidzee', url: 'https://player.vidzee.wtf/embed' },
      { name: '111movies', url: 'https://www.111movies.com/embed' }
    ];
    this.currentProvider = 0;
  }

  embedMovie(imdbId) {
    this.loadProvider('movie', imdbId);
  }

  embedEpisode(imdbId, season, episode) {
    this.loadProvider('tv', imdbId, season, episode);
  }

  loadProvider(type, id, season, episode) {
    const provider = this.providers[this.currentProvider];
    let url;

    if (type === 'movie') {
      url = `${provider.url}/movie/${id}`;
    } else {
      url = `${provider.url}/tv/${id}/${season}/${episode}`;
    }

    const iframe = document.createElement('iframe');
    iframe.src = url;
    iframe.width = '100%';
    iframe.height = '500px';
    iframe.frameBorder = '0';
    iframe.allowFullscreen = true;
    iframe.id = 'video-player';

    // Handle loading errors
    iframe.onerror = () => {
      console.error(`Provider ${provider.name} failed, trying next...`);
      this.switchProvider(type, id, season, episode);
    };

    this.container.innerHTML = '';
    this.container.appendChild(iframe);

    // Add provider selector
    this.addProviderSelector(type, id, season, episode);
  }

  switchProvider(type, id, season, episode) {
    this.currentProvider = (this.currentProvider + 1) % this.providers.length;
    this.loadProvider(type, id, season, episode);
  }

  addProviderSelector(type, id, season, episode) {
    const selector = document.createElement('div');
    selector.className = 'provider-selector';
    selector.innerHTML = `
      <label>Video Source:</label>
      <select id="provider-select">
        ${this.providers.map((p, i) => 
          `<option value="${i}" ${i === this.currentProvider ? 'selected' : ''}>
            ${p.name}
          </option>`
        ).join('')}
      </select>
    `;

    selector.querySelector('select').addEventListener('change', (e) => {
      this.currentProvider = parseInt(e.target.value);
      this.loadProvider(type, id, season, episode);
    });

    this.container.insertBefore(selector, this.container.firstChild);
  }
}

// Usage
const player = new MultiProviderPlayer('player-container');
player.embedMovie('tt0137523');
```

### Complete Streaming Website Implementation

```javascript
// Full-featured streaming site with TMDB + Embed Services

class StreamingSite {
  constructor() {
    this.tmdbApiKey = 'YOUR_TMDB_API_KEY';
    this.tmdbBaseUrl = 'https://api.themoviedb.org/3';
    this.imageBaseUrl = 'https://image.tmdb.org/t/p';
    this.embedProviders = [
      'https://vidsrc.to/embed',
      'https://vidfast.to/embed',
      'https://player.vidzee.wtf/embed'
    ];
    this.currentProvider = 0;
  }

  // Search for movies
  async searchMovies(query) {
    const response = await fetch(
      `${this.tmdbBaseUrl}/search/movie?api_key=${this.tmdbApiKey}&query=${encodeURIComponent(query)}`
    );
    const data = await response.json();
    return data.results;
  }

  // Get movie details
  async getMovieDetails(movieId) {
    const response = await fetch(
      `${this.tmdbBaseUrl}/movie/${movieId}?api_key=${this.tmdbApiKey}&append_to_response=videos,credits,external_ids`
    );
    return await response.json();
  }

  // Get TV show details
  async getTVDetails(tvId, season, episode) {
    const response = await fetch(
      `${this.tmdbBaseUrl}/tv/${tvId}?api_key=${this.tmdbApiKey}&append_to_response=external_ids`
    );
    return await response.json();
  }

  // Display movie
  async displayMovie(tmdbId) {
    const movie = await this.getMovieDetails(tmdbId);
    const imdbId = movie.external_ids.imdb_id;

    // Display movie info
    document.getElementById('movie-title').textContent = movie.title;
    document.getElementById('movie-overview').textContent = movie.overview;
    document.getElementById('movie-poster').src = 
      `${this.imageBaseUrl}/w500${movie.poster_path}`;
    document.getElementById('movie-rating').textContent = 
      movie.vote_average.toFixed(1);

    // Embed player
    this.embedMovie(imdbId);
  }

  // Embed movie
  embedMovie(imdbId) {
    const provider = this.embedProviders[this.currentProvider];
    const iframe = document.createElement('iframe');
    iframe.src = `${provider}/movie/${imdbId}`;
    iframe.width = '100%';
    iframe.height = '500px';
    iframe.frameBorder = '0';
    iframe.allowFullscreen = true;

    const playerContainer = document.getElementById('player');
    playerContainer.innerHTML = '';
    playerContainer.appendChild(iframe);
  }

  // Embed TV episode
  embedEpisode(imdbId, season, episode) {
    const provider = this.embedProviders[this.currentProvider];
    const iframe = document.createElement('iframe');
    iframe.src = `${provider}/tv/${imdbId}/${season}/${episode}`;
    iframe.width = '100%';
    iframe.height = '500px';
    iframe.frameBorder = '0';
    iframe.allowFullscreen = true;

    const playerContainer = document.getElementById('player');
    playerContainer.innerHTML = '';
    playerContainer.appendChild(iframe);
  }

  // Switch provider
  switchProvider() {
    this.currentProvider = (this.currentProvider + 1) % this.embedProviders.length;
  }
}

// Initialize
const site = new StreamingSite();

// Search functionality
document.getElementById('search-btn').addEventListener('click', async () => {
  const query = document.getElementById('search-input').value;
  const results = await site.searchMovies(query);
  displaySearchResults(results);
});

function displaySearchResults(results) {
  const container = document.getElementById('search-results');
  container.innerHTML = results.map(movie => `
    <div class="movie-card" onclick="site.displayMovie(${movie.id})">
      <img src="https://image.tmdb.org/t/p/w185${movie.poster_path}" />
      <h3>${movie.title}</h3>
      <p>Rating: ${movie.vote_average.toFixed(1)}</p>
    </div>
  `).join('');
}
```

